<Window x:Class="RandomNumber.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="500" Width="600">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LABEL CHE MOSTRA LE LETTERE CHE SONO STATE ESTRATTE -->
        <Label x:Name="lblElenco" Grid.Row="0" Grid.ColumnSpan="2" 
               Background="LightGray" FontSize="36" 
               HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />

        <!-- LABEL CHE MOSTRA LE LETTERE CHE GIRANO IN CONTINUAZIONE-->
        <Label x:Name="lblLetteraEstratta" Grid.Row="1" Grid.Column="0" 
               Background="White" FontSize="150" FontWeight="Bold" Margin="10"
               HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />

        <!-- BOTTONE DI AVVIO DELLA "ROTAZIONE" CASUALE DELLE LETTERE-->
       <Button x:Name="btnStart" Grid.Row="2" Grid.Column="0" 
               Content="START" Click="btnStart_Click" 
               FontSize="26" FontWeight="Bold" Margin="10" />
        
        <!-- BOTTONE DI ESTRAZIONE DI UNA LETTERA -->
        <Button x:Name="btnEstrai" Grid.Row="2" Grid.Column="1"   
                Content="ESTRAI LETTERA" Click="btnEstrazione_Click" 
                FontSize="26" FontWeight="Bold" Margin="10" />

    </Grid>
</Window>